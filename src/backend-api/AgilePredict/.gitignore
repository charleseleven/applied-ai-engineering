*.vssscc
.builds
*.pidb
*.svclog
*.scc

# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/

# Microsoft Azure Build Output
csx/
*.build.csdef

# Node modules (se usar frontend)
node_modules/

# Others
*.Cache
ClientBin/
[Ss]tyle[Cc]op.*
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
orleans.codegen.cs

# Backup & report files
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
ServiceFabricBackup/
*.rptproj.bak

# SQL Server files
*.mdf
*.ldf
*.ndf

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Mac files
.DS_Store

